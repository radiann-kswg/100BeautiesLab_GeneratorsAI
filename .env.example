# =============================================================================
# .env.example — 100BeautiesLab_GeneratorsAI 環境変数テンプレート
# Copyright © RadianN_kswg — CC BY-NC 4.0
#
# 使い方:  cp .env.example .env  してから値を埋める。
# ★ .env は絶対にコミットしない (.gitignore で除外済み)。
# ※ これはテンプレートです。実際の鍵はここには書かないでください。
# =============================================================================

# --- Google Gemini / Imagen -------------------------------------------------
GEMINI_API_KEY=
# 使用モデル (デフォルト: imagen-4.0-generate-001)
# 注: Gemini API では imagen-3.0-* は廃止済み。現行は imagen-4.0-* のみ利用可。
IMAGEN_MODEL=imagen-4.0-generate-001
# 参照入力モード用 multimodal モデル
GEMINI_REFERENCE_MODEL=models/gemini-3.1-flash-image

# --- OpenAI (DALL-E 3 / gpt-image-1 / GPT-4o) -------------------------------
OPENAI_API_KEY=
# dall-e-3 が NotFound の環境では gpt-image-1 に切替
DALLE_MODEL=dall-e-3
# gpt-image-1 では medium / high が有効
OPENAI_IMAGE_QUALITY=standard
# prompt-assist モード用
GPT_MODEL=gpt-4o

# --- Adobe Firefly Services (provider: adobe) -------------------------------
# Adobe Developer Console の OAuth Server-to-Server 資格情報
# https://developer.adobe.com/firefly-services/docs/firefly-api/
FIREFLY_CLIENT_ID=
FIREFLY_CLIENT_SECRET=
# 生成サイズ (例: 1024x1024 / 2048x2048 / 1792x1024)
FIREFLY_SIZE=1024x1024
# 任意: モデルバージョン指定 (省略時は API デフォルト)
FIREFLY_MODEL=

# --- Canva Connect API (provider: canva) ------------------------------------
# Canva Connect は user OAuth トークンが必要 (client_credentials 不可)。
# https://www.canva.dev/docs/connect/ で OAuth を済ませ、取得した
# アクセストークンを設定する。Connect API にテキスト→画像生成は無いため、
# canva プロバイダは「生成済み画像を Canva デザイン化して PNG 書き出し」する
# 後段(フィニッシング)ツールとして動作する (--from-image 必須)。
CANVA_ACCESS_TOKEN=
# 任意: 書き出しフォーマット (png / jpg / pdf)。デフォルト png
CANVA_EXPORT_FORMAT=png

# --- MCP サーバ（src/mcp_server/）------------------------------------------
# ローカル stdio の場合は stdio、GCE/Cloud Run のリモート運用では streamable-http
MCP_TRANSPORT=stdio
# HTTP transport 時のバインドアドレスとポート（外部非公開。前段に Caddy/nginx を置く）
HOST=127.0.0.1
PORT=8000
# リモート HTTP 運用時の公開 URL（OAuth discovery の issuer として使用）
# GCE/Cloud Run では必ず設定する。ローカル stdio の場合は空のままでよい。
MCP_ISSUER_URL=

# --- 出力先 -----------------------------------------------------------------
# 出力ベースディレクトリ (互換のため OUTPUT_DIR も読まれる)
OUTPUT_BASE_DIR=output

# Drive シンク用ユーザー OAuth（OUTPUT_SINK=drive 時に必須）
# SA はストレージ容量 0 のため ADC では storageQuotaExceeded になる。
# GCP Console で OAuth クライアント ID（デスクトップ型）を作成し、
# scripts/get_drive_token.py でリフレッシュトークンを取得して設定する。
DRIVE_CLIENT_ID=
DRIVE_CLIENT_SECRET=
DRIVE_REFRESH_TOKEN=

# --- 創作 DB 実物 API (database.numbertales-radiann.net) --------------------
# addon-ai-tag ブランチで公開されている AIHints エンドポイント等にアクセスする際に必要。
# 通常の公開エンドポイント (/api/v1/works/…) はトークン不要。
# API トークンは creations-db リポジトリ管理者から別途取得する。
CREATIONS_DB_API_TOKEN=
# 実物 API のベース URL (通常は変更不要)
CREATIONS_DB_API_BASE_URL=https://database.numbertales-radiann.net/api/v1

# --- SDXL + 作風LoRA プロバイダ (B案・GCE VM SSH バッチ) ---------------------
# docs/usage-generation.md §3-5-3 参照。VM 起動を伴うため課金注意。
SDXL_GCP_PROJECT=claude-radiannkswg
SDXL_VM_NAME=lora-l4-trial
SDXL_VM_ZONE=asia-east1-b
SDXL_REMOTE_WORKDIR=/home/s-chi/sdxl-infer
# (必須) VM 上の Illustrious-XL チェックポイント / LoRA 重みの絶対パス
SDXL_REMOTE_BASE_MODEL=
SDXL_REMOTE_LORA=
SDXL_LORA_SCALE=0.8
# 推論に使う VM 上の python (diffusers/peft 入りの venv を指定推奨。default: python3)
SDXL_REMOTE_PYTHON=/home/s-chi/sd-scripts/venv/bin/python

# --- その他 -----------------------------------------------------------------
# 形態共通データセットを明示指定したいときだけ
FORM_COMMON_DATASET_PATH=
# 創作 DB パッケージ参照を一時的に無効化したい場合は 0
CREATIONS_DB_PACKAGE_ENABLE=1
